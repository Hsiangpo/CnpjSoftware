# LLM is optional and OFF by default — rule-based role ranking handles this data.
# Set LLM_ENABLED=true (and LLM_API_KEY) to turn the LLM analysis path back on.
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URLS=https://api.gpteamservices.com/v1,https://api-hk.gpteamservices.com/v1,https://api-us.gpteamservices.com/v1,https://api-jp.gpteamservices.com/v1
LLM_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=
LLM_TIMEOUT_SECONDS=30
SYSTEM_CONCURRENCY=3
CNPJ_PROVIDER_ORDER=brasilapi,cnpjbiz
CNPJ_BIZ_REQUEST_DELAY_SECONDS=0.8
CNPJ_BIZ_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36
BLURPATH_PROXY_HOST=blurpath.net
BLURPATH_PROXY_PORT=15133
BLURPATH_PROXY_PORTS=15129,15121
BLURPATH_PROXY_PROTOCOL=http
# Either the base Blurpath account name or the full dashboard-generated proxy username.
BLURPATH_PROXY_USERNAME=
BLURPATH_PROXY_PASSWORD=
# Optional raw dashboard-generated node list, separated by `|`, `,`, or newlines.
BLURPATH_PROXY_NODES=
BLURPATH_PROXY_REGION=BR
BLURPATH_PROXY_SESSION_TIME_MINUTES=10
# Optional exact login template. Supports {username}, {region}, {session}, {session_time}.
BLURPATH_PROXY_USERNAME_TEMPLATE=
